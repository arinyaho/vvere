# PostgreSQL
POSTGRES_PASSWORD=changeme

# GitHub PAT (needs repo + workflow read scopes)
GITHUB_TOKEN=ghp_...

# Google OAuth2 (create at console.cloud.google.com → APIs & Services → Credentials)
# Authorized redirect URI: http://<your-host>:9339/api/auth/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=

# Public URL (used for OAuth callback)
PUBLIC_URL=http://localhost:9339

# Only this domain can log in
ALLOWED_DOMAIN=your-company.com

# Collector settings
COLLECT_INTERVAL_SECONDS=300
STALE_DAYS=3
RETENTION_DAYS=90

# How far back to fetch on first run (days): 7 / 30 / 90 / 180 / 365
INITIAL_FETCH_DAYS=90

# Repos to track (comma-separated owner/repo). Seeded into DB on collector startup.
# Example: REPOS=my-org/service-a,my-org/service-b
REPOS=


# AI-powered recommendations (optional — works without it, rules-only mode)
# Get your key at console.anthropic.com
# ANTHROPIC_API_KEY=sk-ant-...
# LLM_MODEL=claude-sonnet-4-6
